@@ -1,0 +1,95 @@
+import pandas as pd
+from pymongo import MongoClient
+
+# Read the CSV file
+df = pd.read_csv('wtv.csv')
+
+# Function to transform the dataframe into a MongoDB-friendly format
+def transform_dataframe(df):
+    # Create a list to store transformed documents
+    documents = []
+
+    for _, row in df.iterrows():
+        # Create the base document structure
+        doc = {
+            '_id': row['_id'],
+            'qualifications': {
+                'is_cambodian': row['qualifications.is_cambodian'],
+                'sent_received_items': row['qualifications.sent_received_items'],
+                'used_logistics_app': row['qualifications.used_logistics_app']
+            },
+            'imageSelections': {
+                'natureOfGoods': {
+                    'Less_Technical': row['imageSelections.natureOfGoods.Less_Technical'],
+                    'More_Technical': row['imageSelections.natureOfGoods.More_Technical'],
+                    'Intuitive': row['imageSelections.natureOfGoods.Intuitive'],
+                    'Informative': row['imageSelections.natureOfGoods.Informative'],
+                    'Professional': row['imageSelections.natureOfGoods.Professional'],
+                    'Simplicity': row['imageSelections.natureOfGoods.Simplicity'],
+                    'Concise': row['imageSelections.natureOfGoods.Concise'],
+                    'Clarity': row['imageSelections.natureOfGoods.Clarity'],
+                    'CustomReason': row['imageSelections.natureOfGoods.CustomReason'],
+                    'original': row['imageSelections.natureOfGoods']
+                },
+                'hs': {
+                    # Removed 'wording' layer from 'hs'
+                    'Less_Technical': row['imageSelections.hs.Less_Technical'],
+                    'More_Technical': row['imageSelections.hs.More_Technical'],
+                    'Intuitive': row['imageSelections.hs.Intuitive'],
+                    'Informative': row['imageSelections.hs.Informative'],
+                    'Professional': row['imageSelections.hs.Professional'],
+                    'Simplicity': row['imageSelections.hs.Simplicity'],
+                    'Concise': row['imageSelections.hs.Concise'],
+                    'Clarity': row['imageSelections.hs.Clarity'],
+                    'CustomReason': row['imageSelections.hs.CustomReason'],
+                    'original': row['imageSelections.hs']
+                },
+                'serviceRepresentation': {
+                    'Less_Technical': row['imageSelections.serviceRepresentation.Less_Technical'],
+                    'More_Technical': row['imageSelections.serviceRepresentation.More_Technical'],
+                    'Intuitive': row['imageSelections.serviceRepresentation.Intuitive'],
+                    'Informative': row['imageSelections.serviceRepresentation.Informative'],
+                    'Professional': row['imageSelections.serviceRepresentation.Professional'],
+                    'Simplicity': row['imageSelections.serviceRepresentation.Simplicity'],
+                    'Concise': row['imageSelections.serviceRepresentation.Concise'],
+                    'Clarity': row['imageSelections.serviceRepresentation.Clarity'],
+                    'hsCustomReason': row['imageSelections.serviceRepresentation.hsCustomReason'],
+                    'original': row['imageSelections.serviceRepresentation']
+                },
+                'weightVisualization': {
+                    'Less_Technical': row['imageSelections.weightVisualization.Less_Technical'],
+                    'More_Technical': row['imageSelections.weightVisualization.More_Technical'],
+                    'Intuitive': row['imageSelections.weightVisualization.Intuitive'],
+                    'Informative': row['imageSelections.weightVisualization.Informative'],
+                    'Professional': row['imageSelections.weightVisualization.Professional'],
+                    'Simplicity': row['imageSelections.weightVisualization.Simplicity'],
+                    'Concise': row['imageSelections.weightVisualization.Concise'],
+                    'Clarity': row['imageSelections.weightVisualization.Clarity'],
+                    'hsCustomReason': row['imageSelections.weightVisualization.hsCustomReason'],
+                    'original': row['imageSelections.weightVisualization']
+                }
+            }
+        }
+
+        # Replace empty strings with None for proper MongoDB handling
+        def replace_empty_with_none(obj):
+            if isinstance(obj, dict):
+                return {k: replace_empty_with_none(v) for k, v in obj.items() if v != ''}
+            return obj
+
+        doc = replace_empty_with_none(doc)
+        documents.append(doc)
+
+    return documents
+
+
+# Connect to MongoDB
+client = MongoClient('mongodb://localhost:27017/')
+db = client['your_database_name']
+collection = db['your_collection_name']
+
+# Transform and insert documents
+documents = transform_dataframe(df)
+collection.insert_many(documents)
+
+print(f"Inserted {len(documents)} documents")
