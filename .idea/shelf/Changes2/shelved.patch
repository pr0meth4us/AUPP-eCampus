+import os
+
+def combine_course_folder_contents(base_dir, output_file):
+    """
+    Recursively search for all files under folders named 'course' and
+    combine their contents into a single file.
+
+    Parameters:
+    base_dir (str): The base directory to start the search.
+    output_file (str): The path to the output file where content will be combined.
+    """
+    combined_content = []
+
+    def recurse_directory(current_dir):
+        for root, dirs, files in os.walk(current_dir):
+            # Check if 'course' is in the current path
+            if 'course' in root.split(os.sep):
+                for file in files:
+                    file_path = os.path.join(root, file)
+                    try:
+                        with open(file_path, 'r', encoding='utf-8') as f:
+                            combined_content.append(f.read())
+                    except Exception as e:
+                        print(f"Error reading file {file_path}: {e}")
+
+    recurse_directory(base_dir)
+
+    # Write combined content to the output file
+    try:
+        with open(output_file, 'w', encoding='utf-8') as out_file:
+            out_file.write("\n".join(combined_content))
+        print(f"Combined content written to {output_file}")
+    except Exception as e:
+        print(f"Error writing to output file {output_file}: {e}")
+
+# Example usage
+combine_course_folder_contents('/Users/nicksng/Desktop/code/AUPP-eCampus/backend', 'combined_output.txt')
